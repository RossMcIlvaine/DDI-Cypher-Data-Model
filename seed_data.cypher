    rationale:   'Patient education is important',
    reference:   'Ann Pharmacother'
  }
] AS row

// 4a. MERGE Interaction node
MERGE (i:Interaction {id: row.id})
  ON CREATE SET
    i.severity  = row.severity,
    i.effect    = row.effect,
    i.reference = row.reference

// 4b. MATCH both Drug nodes
WITH i, row
MATCH (da:Drug {name: row.drug_a})
MATCH (db:Drug {name: row.drug_b})

// 4c. Link drugs to Interaction node
MERGE (da)-[:PARTICIPATES_IN]->(i)
MERGE (db)-[:PARTICIPATES_IN]->(i)

// 4d. Direct labeled edge for fast pair lookups
MERGE (da)-[r:INTERACTS_WITH]->(db)
  ON CREATE SET
    r.severity  = row.severity,
    r.effect    = row.effect,
    r.reference = row.reference

// 4e. Link Interaction to Mechanism
WITH i, row
MATCH (m:Mechanism {description: row.mechanism})
MERGE (i)-[:HAS_MECHANISM]->(m)

// 4f. Link Interaction to SaferAlternative
WITH i, row
MATCH (s:SaferAlternative {name: row.safer_alt})
MERGE (i)-[rel:HAS_SAFER_ALTERNATIVE]->(s)
  ON CREATE SET rel.rationale = row.rationale;
